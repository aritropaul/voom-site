---
import Icon from "./Icon.astro";

const repo = "https://github.com/aritropaul/voom";
const groups = [
  {
    title: "Product",
    links: [
      { href: "/download", label: "Download" },
      { href: "/pricing", label: "Pricing" },
      { href: "/loom-alternative", label: "vs Loom" },
      { href: "/self-host", label: "Self-host" },
    ],
  },
  {
    title: "Project",
    links: [
      { href: repo, label: "Source", ext: true },
      { href: `${repo}/releases/latest`, label: "Releases", ext: true },
      { href: `${repo}/issues`, label: "Issues", ext: true },
      { href: `${repo}/blob/main/LICENSE`, label: "MIT License", ext: true },
    ],
  },
  {
    title: "More",
    links: [
      { href: "/about", label: "About" },
      { href: "/privacy", label: "Privacy" },
      { href: "/faq", label: "FAQ" },
      { href: "mailto:voom@aritro.xyz", label: "Contact" },
    ],
  },
];
---
<footer class="relative mt-12 border-t" style="border-color: var(--color-hair)">
  <div class="container-x py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div class="max-w-[260px]">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/icon.png" alt="" width="30" height="30" class="rounded-[9px]" />
          <span class="text-[16px] font-semibold" style="color: var(--color-title)">Voom</span>
        </a>
        <p class="mt-3.5 text-[13.5px] leading-relaxed" style="color: var(--color-muted)">
          Open-source, privacy-first screen recording for macOS. Record, transcribe on-device, and share through infrastructure you own.
        </p>
        <div class="mt-4 flex items-center gap-2">
          <a href={repo} target="_blank" rel="noopener" aria-label="GitHub" class="flex h-9 w-9 items-center justify-center rounded-lg border transition-colors" style="border-color: var(--color-hair); color: var(--color-muted)">
            <Icon name="github" class="h-[18px] w-[18px]" />
          </a>
          <span class="pill"><Icon name="check" class="h-3.5 w-3.5" /> MIT licensed</span>
        </div>
      </div>

      {groups.map((g) => (
        <div>
          <h4 class="mb-3.5 font-mono text-[11px] uppercase tracking-[0.18em]" style="color: var(--color-faint)">{g.title}</h4>
          <ul class="space-y-2.5">
            {g.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  target={l.ext ? "_blank" : undefined}
                  rel={l.ext ? "noopener" : undefined}
                  class="text-[13.5px] transition-colors hover:opacity-100"
                  style="color: var(--color-body)"
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t pt-6 text-[12.5px] sm:flex-row sm:items-center" style="border-color: var(--color-hair); color: var(--color-faint)">
      <p>© 2026 Voom — built with Swift, shipped in the open.</p>
      <p>Not affiliated with Loom. macOS 15+ · Apple Silicon + Intel.</p>
    </div>
  </div>
</footer>
